<launch>
  <!-- Project-local AMCL configuration tuned for long, feature-poor corridors.
       Differences vs the default jackal_navigation amcl.launch:
       - more particles  (better hypothesis coverage in symmetric environments)
       - more frequent updates (smaller update_min_d / update_min_a)
       - tighter laser noise model + more beams (sharper likelihood field)
       - lower odometry noise (we trust /odometry/filtered which is EKF-fused)
       - recovery alphas enabled (so AMCL can re-converge after divergence) -->

  <arg name="use_map_topic" default="false"/>
  <arg name="scan_topic" default="$(eval optenv('JACKAL_LASER_TOPIC', 'front/scan'))" />
  <arg name="initial_pose_x" default="0.0"/>
  <arg name="initial_pose_y" default="0.0"/>
  <arg name="initial_pose_a" default="0.0"/>

  <node pkg="amcl" type="amcl" name="amcl">
    <param name="use_map_topic" value="$(arg use_map_topic)"/>
    <param name="odom_model_type" value="diff"/>
    <param name="gui_publish_rate" value="20.0"/>

    <!-- Sensor model -->
    <param name="laser_max_beams" value="2000"/>
    <param name="laser_min_range" value="-1"/>
    <param name="laser_max_range" value="-1"/>
    <param name="laser_z_hit" value="0.7"/>
    <param name="laser_z_short" value="0.05"/>
    <param name="laser_z_max" value="0.05"/>
    <param name="laser_z_rand" value="0.2"/>
    <param name="laser_sigma_hit" value="0.2"/>
    <param name="laser_lambda_short" value="0.1"/>
    <param name="laser_model_type" value="likelihood_field"/>
    <param name="laser_likelihood_max_dist" value="6.0"/>

    <!-- Particle filter -->
    <param name="min_particles" value="1500"/>
    <param name="max_particles" value="5000"/>
    <param name="kld_err" value="0.02"/>
    <param name="kld_z" value="0.99"/>

    <!-- Odometry noise (default jackal values) -->
    <param name="odom_alpha1" value="1.0"/>
    <param name="odom_alpha2" value="1.0"/>
    <param name="odom_alpha3" value="1.0"/>
    <param name="odom_alpha4" value="1.0"/>
    <param name="odom_alpha5" value="0.1"/>

    <!-- Update very frequently so corrections accumulate before drifting -->
    <param name="update_min_d" value="0.05"/>
    <param name="update_min_a" value="0.05"/>
    <param name="resample_interval" value="1"/>

    <!-- Recovery: allow random pose injection if we lose track -->
    <param name="recovery_alpha_slow" value="0.001"/>
    <param name="recovery_alpha_fast" value="0.1"/>

    <param name="odom_frame_id" value="odom"/>
    <param name="base_frame_id" value="base_link"/>
    <param name="global_frame_id" value="map"/>
    <param name="transform_tolerance" value="1.0"/>

    <!-- Initial pose: set via launch args so it matches spawn point -->
    <param name="initial_pose_x" value="$(arg initial_pose_x)"/>
    <param name="initial_pose_y" value="$(arg initial_pose_y)"/>
    <param name="initial_pose_a" value="$(arg initial_pose_a)"/>
    <param name="initial_cov_xx" value="0.1"/>
    <param name="initial_cov_yy" value="0.1"/>
    <param name="initial_cov_aa" value="0.05"/>

    <param name="receive_map_topic" value="true"/>
    <param name="first_map_only" value="true"/>
    <remap from="scan" to="$(arg scan_topic)"/>
  </node>
</launch>
